# Environment Configuration
# Copy this file to .env and customize as needed

# ROS Distribution
ROS_DISTRO=jazzy

# Gazebo version
GZ_VERSION=harmonic

# Build type (Release, Debug, RelWithDebInfo)
BUILD_TYPE=RelWithDebInfo

# Display (usually auto-detected)
# Uncomment and set manually if needed
# DISPLAY=:0

# Python path for ROS2
# Usually set automatically by sourcing setup.bash
# PYTHONPATH=/opt/ros/jazzy/lib/python3.12/site-packages

# Gazebo resource paths (set automatically by GZ_VERSION)
# GZ_SIM_RESOURCE_PATH=/workspace/src/inverted_pendulum/inverted_pendulum_gazebo/worlds
