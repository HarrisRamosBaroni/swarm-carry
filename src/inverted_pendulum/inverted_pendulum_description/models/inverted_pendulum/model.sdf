<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="inverted_pendulum">

    <!-- New top-level link (canonical) -->
    <link name="base">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.01</mass> <!-- Nonzero mass to avoid other warnings -->
        <!-- <mass>0.0</mass> Massless for stability -->
      </inertial>
    </link>

    <!-- Existing links/joints -->
    <link name="cart">
      <pose>0.0 0 0 0 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.1</ixx>
          <iyy>0.1</iyy>
          <izz>0.1</izz>
        </inertia>
      </inertial>
      <visual name="visual_cart">
        <geometry>
          <box>
            <size>1 0.5 0.2</size>
          </box>
        </geometry>
      </visual>
      <collision name="collision_cart">
        <geometry>
          <box>
            <size>1 0.5 0.2</size>
          </box>
        </geometry>
      </collision>
    </link>

    <link name="pendulum">
      <pose>0.0 0 0.55 0 0 0.6</pose>
      <inertial>
        <mass>1</mass>
        <inertia>
          <ixx>0.05</ixx>
          <iyy>0.05</iyy>
          <izz>0.05</izz>
        </inertia>
      </inertial>
      <visual name="visual_pendulum">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>1</length>
          </cylinder>
        </geometry>
      </visual>
      <collision name="collision_pendulum">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>1</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- JOINT stuff -->
    <joint name="pendulum_joint" type="revolute">
      <parent>cart</parent>
      <child>pendulum</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-3.14</lower>
          <upper>3.14</upper>
        </limit>
      <!-- <initial_position>0.6</initial_position> -->
      </axis>
    </joint>

    <joint name="cart_joint" type="prismatic">
      <parent>base</parent>
      <child>cart</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-8</lower>
          <upper>8</upper>
        </limit>
        <!-- <initial_position>2.0</initial_position> -->
      </axis>
    </joint>

    <!-- ROS2 CONTROL stuff -->
    <ros2_control name="GazeboSimSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="cart_joint">
        <command_interface name="effort">
          <param name="min">-1000000</param>
          <param name="max">1000000</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">2.0</param>
        </state_interface>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="pendulum_joint">
        <state_interface name="position">
          <param name="initial_value">0.6</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <!-- PLUGIN stuff -->
    <!-- Publish joint states on gazebo's /world/demo/model/inverted_pendulum/joint_state topic -->
    <plugin name="gz::sim::systems::JointStatePublisher" filename="gz-sim-joint-state-publisher-system">
      <joint_name>pendulum_joint</joint_name>
      <joint_name>cart_joint</joint_name>
    </plugin>

                                                 <!-- Legacy gazebo classic -->
    <!-- <plugin name="gazebo_ros2_control"  filename="libgazebo_ros2_control.so" >
      <robotNamespace>/</robotNamespace>
    </plugin> -->


    <!-- This plugin blocks sets up the controller manager, and we set the name controller_manager -->
    <!-- We also pass the cart_controllers.yaml file as a config file to set up the controller manager -->
    <!-- "In addition to the ros2_control tags, a Gazebo plugin needs to be added to your URDF or SDF that actually parses the ros2_control tags and loads the appropriate hardware interfaces and controller manager" -->
                                                                        <!--  gazebo sim (harmonic) -->
    <!-- <plugin name="gz_ros2_control::GazeboSimROS2ControlPlugin" filename="gz_ros2_control-system"> -->
      <!-- <parameters>$(find inverted_pendulum_controller)/config/cart_controllers.yaml</parameters> -->
      <!-- <parameters>$(fdfind inverted_pendulum_controller)/config/cart_controllers.yaml</parameters> -->
      <!-- <controller_manager_prefix_node_name>controller_manager</controller_manager_prefix_node_name> -->
    <plugin name="gz_ros2_control::GazeboSimROS2ControlPlugin" filename="libgz_ros2_control-system.so">
      <parameters>/workspaces/pendulum_challenge_ws/src/inverted_pendulum/inverted_pendulum_controller/config/cart_controllers.yaml</parameters>
    </plugin>

    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/workspaces/pendulum_challenge_ws/src/inverted_pendulum/inverted_pendulum_controller/config/cart_controllers.yaml</parameters>
    </plugin>


    <!-- <plugin filename="your_control_plugin" name="your::control::Plugin"/> -->
    <!-- Optionally include PID parameters if using force mode -->
    <!-- <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>cart_joint</joint_name>
      <initial_position>2000.0</initial_position>
      <initial_velocity>0.001</initial_velocity>
      <use_force_commands>true</use_force_commands>
      <p_gain>10.0</p_gain>
      <i_gain>0.1</i_gain>

      <joint_name>pendulum_joint</joint_name>
      <initial_position>6000.0</initial_position>
      <initial_velocity>0.001</initial_velocity>
    </plugin> -->

    <!-- <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>cart_joint</joint_name>
      <initial_position>2.0</initial_position>
      <initial_velocity>0.001</initial_velocity>
      <use_force_commands>true</use_force_commands>
      <p_gain>100.0</p_gain>
      <i_gain>0.1</i_gain>
    </plugin> -->

    <!-- <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>pendulum_joint</joint_name>
      <initial_position>0.6</initial_position>
      <initial_velocity>0.001</initial_velocity>
      <use_force_commands>true</use_force_commands>
      <p_gain>5.0</p_gain>
      <i_gain>0.05</i_gain>
    </plugin> -->

    <!-- Keep the JointController plugin for pendulum_joint, but only for initial positioning -->
    <!-- <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController"> -->
      <!-- <joint_name>pendulum_joint</joint_name> -->
      <!-- <initial_position>0.6</initial_position> -->
      <!-- <initial_velocity>0.0</initial_velocity> -->
      <!-- Remove PID gains and force commands to prevent active control -->
    <!-- </plugin> -->

    <!-- Add a plugin to apply forces to cart_joint -->
    <!-- <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>cart_joint</joint_name>
    </plugin> -->

  </model>
</sdf>