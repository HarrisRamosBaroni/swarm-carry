<?xml version="1.0" ?>
<robot name="inverted_pendulum">

  <!-- LINKS -->
  <link name="world"/>

  <link name="base">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="cart">
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    <inertial>
      <mass value="2"/>
      <!-- <inertia ixx="0.1" iyy="0.1" izz="0.1"/> -->
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="1 0.5 0.2"/>
      </geometry>
    </visual>
  </link>


        <!-- <inertia
        ixx="${mass / 12.0 * (width*width + height*height)}" ixy="0.0" ixz="0.0"
        iyy="${mass / 12.0 * (height*height + width*width)}" iyz="0.0"
        izz="${mass / 12.0 * (width*width + width*width)}"/> -->
  <!-- 
  >>> mass = 1
  >>> height = 1
  >>> width = 0.05
  >>> width = 0.1
  >>> iyy = mass / 12.0 * (width*width + height*height)
  >>> iyy
  0.08416666666666667
  >>> ixx = mass / 12.0 * (height*height + width*width)
  >>> ixx
  0.08416666666666667
  >>> izz = mass / 12.0 * (2*width*width)
  >>> izz
  0.001666666666666667 
  -->
  <link name="pendulum">
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <!-- <inertial>
      <mass value="1"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0" ixz="0" iyz="0"/>
    </inertial> -->
    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="1"/>
        <inertia
        ixx="0.084" ixy="0.0" ixz="0.0"
        iyy="0.084" iyz="0.0"
        izz="0.0017"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="1" radius="0.05"/>
      </geometry>
    </visual>
  </link>
  
  <!-- JOINTS -->
  <joint name="world_to_base" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="world"/>
    <child link="base"/>
  </joint>
  
  <joint name="cart_joint" type="prismatic">
    <axis xyz="1 0 0"/>
    <origin xyz="0.0 0.0 0.0"/>
    <parent link="base"/>
    <child link="cart"/>
    <limit effort="1000.0" lower="-8" upper="8" velocity="30"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
  
  <!-- <joint name="pendulum_joint" type="revolute">
    <axis xyz="0 1 0"/>
    <origin xyz="0.0 0.0 0.55"/>
    <parent link="cart"/>
    <child link="pendulum"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="100"/>
  </joint> -->

  <joint name="pendulum_joint" type="revolute">
    <axis xyz="0 1 0"/>
    <origin xyz="0.0 0.0 0.5" rpy="0 0 0"/>
    <parent link="cart"/>
    <child link="pendulum"/>
    <limit effort="10000.0" lower="-1" upper="1" velocity="100000"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- ROS2 CONTROL -->
    <ros2_control name="GazeboSimSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="cart_joint">
        <command_interface name="effort">
          <param name="min">-1000000</param>
          <param name="max">1000000</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">2.0</param>
        </state_interface>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="pendulum_joint">
        <state_interface name="position">
          <param name="initial_value">0.6</param>
        </state_interface>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

  <!-- <ros2_control name="GazeboSimSystem" type="system">
    <hardware/>
    <joint name="cart_joint">
      <command_interface name="effort">
        <param name="min">-1000000</param>
        <param name="max">1000000</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">2.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="pendulum_joint">
      <state_interface name="position">
        <param name="initial_value">0.6</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control> -->

  <!-- PLUGINS -->
  <gazebo>
    <plugin name="gz::sim::systems::JointStatePublisher" filename="gz-sim-joint-state-publisher-system">
      <joint_name>pendulum_joint</joint_name>
      <joint_name>cart_joint</joint_name>
    </plugin>
  </gazebo>
  <!-- <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find inverted_pendulum_controller)/config/diff_drive_controller.yaml</parameters>
    </plugin>
  </gazebo> -->
  <!-- <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/workspaces/pendulum_challenge_ws/src/inverted_pendulum/inverted_pendulum_controller/config/cart_controllers.yaml</parameters>
    </plugin>
  </gazebo> -->
  <!-- Initialise controller manager -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/workspaces/pendulum_challenge_ws/install/share/inverted_pendulum_controller/config/cart_controllers.yaml</parameters>
    </plugin>
  </gazebo>
  <!-- <gazebo>
    <plugin name="gz_ros2_control::GazeboSimROS2ControlPlugin" filename="libgz_ros2_control-system.so">
      <parameters>$(find inverted_pendulum_controller)/config/cart_controllers.yaml</parameters>
    </plugin>
  </gazebo> -->

  <gazebo>
    <plugin
      filename="gz-sim-pose-publisher-system"
      name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>
  </gazebo>


</robot>