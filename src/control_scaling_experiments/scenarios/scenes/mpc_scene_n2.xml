<mujoco model="mpc_scaling_experiment">
  <compiler angle="radian" meshdir="../../../mujoco_swarm_demo/models/assets" autolimits="true"/>

  <option integrator="Euler" timestep="0.005">
    <flag contact="enable" warmstart="enable"/>
  </option>

  <size njmax="500" nconmax="200"/>

  <statistic center="1.5 0 0.4" extent="5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <!-- Textures -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
             rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <!-- Robot meshes -->
    <mesh name="waffle_pi_base" file="waffle_pi_base.stl" scale="0.001 0.001 0.001"/>
    <mesh name="left_tire" file="left_tire.stl" scale="0.001 0.001 0.001"/>
    <mesh name="right_tire" file="right_tire.stl" scale="0.001 0.001 0.001"/>
    <mesh name="lds" file="lds.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <default>
    <joint limited="false" armature="0.01" damping="0.1"/>
    <geom condim="4" friction="1 0.005 0.0001" solimp="0.99 0.99 0.001" solref="0.01 1"/>
    <equality solref="0.0002 1" solimp="0.99 0.99 0.0001"/>
  </default>

  <worldbody>
    <light pos="1.5 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Goal marker (visual only) -->
    <geom name="goal_marker" type="box" size="0.05 0.35 0.01"
          pos="3.0 0.0 0.01" rgba="0.3 0.8 0.3 0.3" contype="0" conaffinity="0"/>

    <!-- Robots -->

    <!-- Robot 0 -->
    <body name="robot_0_base" pos="-0.55 -0.315 0.033" euler="0 0 0.0">
      <freejoint name="robot_0_joint"/>
      <geom pos="-0.064 0 0.01" quat="1 0 0 0" type="mesh" rgba="0.4 0.4 0.4 1" mesh="waffle_pi_base"/>
      <geom size="0.015 0.0045 0.01" pos="-0.177 -0.0639992 0.005" quat="0.707388 -0.706825 0 0" type="box"/>
      <geom size="0.015 0.0045 0.01" pos="-0.177 0.0640008 0.005" quat="0.707388 -0.706825 0 0" type="box"/>
      <geom pos="-0.049 0 0.1255" quat="1 0 0 0" type="mesh" rgba="0.3 0.3 0.3 1" mesh="lds"/>
      <geom size="0.0075 0.015 0.0135" pos="0.078 0 0.107" type="box"/>

      <body name="robot_0_wheel_left" pos="0 0.144 0.033" quat="0.707388 -0.706825 0 0">
        <inertial pos="0 0 0" quat="-0.000890159 0.706886 0.000889646 0.707326" mass="0.0284989" diaginertia="2.07126e-05 1.11924e-05 1.11756e-05"/>
        <joint name="robot_0_wheel_left_joint" pos="0 0 0" axis="0 0 1" limited="false" armature="0.01"/>
        <geom quat="0.707388 0.706825 0 0" type="mesh" rgba="0.3 0.3 0.3 1" mesh="left_tire"/>
      </body>

      <body name="robot_0_wheel_right" pos="0 -0.144 0.033" quat="0.707388 -0.706825 0 0">
        <inertial pos="0 0 0" quat="-0.000890159 0.706886 0.000889646 0.707326" mass="0.0284989" diaginertia="2.07126e-05 1.11924e-05 1.11756e-05"/>
        <joint name="robot_0_wheel_right_joint" pos="0 0 0" axis="0 0 1" limited="false" armature="0.01"/>
        <geom quat="0.707388 0.706825 0 0" type="mesh" rgba="0.3 0.3 0.3 1" mesh="right_tire"/>
      </body>
    </body>

    <!-- Robot 1 -->
    <body name="robot_1_base" pos="-0.55 0.315 0.033" euler="0 0 0.0">
      <freejoint name="robot_1_joint"/>
      <geom pos="-0.064 0 0.01" quat="1 0 0 0" type="mesh" rgba="0.4 0.4 0.4 1" mesh="waffle_pi_base"/>
      <geom size="0.015 0.0045 0.01" pos="-0.177 -0.0639992 0.005" quat="0.707388 -0.706825 0 0" type="box"/>
      <geom size="0.015 0.0045 0.01" pos="-0.177 0.0640008 0.005" quat="0.707388 -0.706825 0 0" type="box"/>
      <geom pos="-0.049 0 0.1255" quat="1 0 0 0" type="mesh" rgba="0.3 0.3 0.3 1" mesh="lds"/>
      <geom size="0.0075 0.015 0.0135" pos="0.078 0 0.107" type="box"/>

      <body name="robot_1_wheel_left" pos="0 0.144 0.033" quat="0.707388 -0.706825 0 0">
        <inertial pos="0 0 0" quat="-0.000890159 0.706886 0.000889646 0.707326" mass="0.0284989" diaginertia="2.07126e-05 1.11924e-05 1.11756e-05"/>
        <joint name="robot_1_wheel_left_joint" pos="0 0 0" axis="0 0 1" limited="false" armature="0.01"/>
        <geom quat="0.707388 0.706825 0 0" type="mesh" rgba="0.3 0.3 0.3 1" mesh="left_tire"/>
      </body>

      <body name="robot_1_wheel_right" pos="0 -0.144 0.033" quat="0.707388 -0.706825 0 0">
        <inertial pos="0 0 0" quat="-0.000890159 0.706886 0.000889646 0.707326" mass="0.0284989" diaginertia="2.07126e-05 1.11924e-05 1.11756e-05"/>
        <joint name="robot_1_wheel_right_joint" pos="0 0 0" axis="0 0 1" limited="false" armature="0.01"/>
        <geom quat="0.707388 0.706825 0 0" type="mesh" rgba="0.3 0.3 0.3 1" mesh="right_tire"/>
      </body>
    </body>

    <!-- Payload cuboid -->
    <body name="payload" pos="0.0 0.0 0.1">
      <freejoint name="payload_joint"/>
      <inertial pos="0 0 0" mass="0.700" diaginertia="0.002917 0.030917 0.029167"/>
      <geom name="payload_geom" type="box" size="0.05 0.35 0.1"
            rgba="0.8 0.4 0.2 0.9" friction="0.8 0.005 0.0001"/>
    </body>
  </worldbody>

  <!-- Actuators -->
  <actuator>

    <velocity name="robot_0_left_actuator" ctrllimited="true" ctrlrange="-30.0 30.0"
              gear="1" kv="1.0" joint="robot_0_wheel_left_joint" />
    <velocity name="robot_0_right_actuator" ctrllimited="true" ctrlrange="-30.0 30.0"
              gear="1" kv="1.0" joint="robot_0_wheel_right_joint" />

    <velocity name="robot_1_left_actuator" ctrllimited="true" ctrlrange="-30.0 30.0"
              gear="1" kv="1.0" joint="robot_1_wheel_left_joint" />
    <velocity name="robot_1_right_actuator" ctrllimited="true" ctrlrange="-30.0 30.0"
              gear="1" kv="1.0" joint="robot_1_wheel_right_joint" />
  </actuator>

  <!-- Sensors -->
  <sensor>
    <!-- Payload state sensors -->
    <framepos name="payload_pos" objtype="body" objname="payload"/>
    <framequat name="payload_quat" objtype="body" objname="payload"/>
    <framelinvel name="payload_vel" objtype="body" objname="payload"/>
  </sensor>
</mujoco>
