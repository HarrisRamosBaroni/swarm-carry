// Dev container configuration with built-in VNC server
// Start VNC: ./scripts/start-vnc.sh then connect to localhost:5901
// Or use browser: ./scripts/start-novnc.sh then http://localhost:6080
{
	"name": "ROS2 Gazebo Simulation",
	"dockerFile": "Dockerfile",
	"build": {
		"args": {
			"WORKSPACE": "${containerWorkspaceFolder}"
		}
	},
	"remoteUser": "ros",
	"runArgs": [
		"--cap-add=SYS_PTRACE",
		"--security-opt=seccomp:unconfined",
		"--security-opt=apparmor:unconfined",
		"--ipc=host"
	],
	"forwardPorts": [6080, 5901],
	"portsAttributes": {
		"6080": {
			"label": "noVNC (Web)",
			"onAutoForward": "ignore"
		},
		"5901": {
			"label": "VNC",
			"onAutoForward": "ignore"
		}
	},
	"containerEnv": {
		"LIBGL_ALWAYS_SOFTWARE": "1"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-iot.vscode-ros",
				"ms-python.python",
				"ms-vscode.cpptools",
				"twxs.cmake",
				"redhat.vscode-yaml",
				"DotJoshJohnson.xml"
			]
		}
	},
	"postCreateCommand": "echo 'Container ready! Start GUI: ./scripts/start-vnc.sh (VNC client: localhost:5901 or browser: ./scripts/start-novnc.sh)'"
}
